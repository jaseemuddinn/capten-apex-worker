{
    "title": "Capten Apex Worker",
    "description": "Hindi to Hinglish speech-to-text using Oriserve/Whisper-Hindi2Hinglish-Apex. Accepts audio_url or audio_base64; returns text and word timestamps for Capten.",
    "type": "serverless",
    "category": "audio",
    "config": {
      "runsOn": "GPU",
      "containerDiskInGb": 20,
      "gpuCount": 1,
      "gpuIds": "ADA_24,AMPERE_24,AMPERE_16",
      "allowedCudaVersions": [
        "12.8",
        "12.7",
        "12.6",
        "12.5",
        "12.4",
        "12.3",
        "12.2",
        "12.1",
        "12.0"
      ],
      "presets": [
        {
          "name": "Hinglish Apex (default)",
          "defaults": {
            "MODEL_ID": "Oriserve/Whisper-Hindi2Hinglish-Apex"
          }
        }
      ],
      "env": [
        {
          "key": "MODEL_ID",
          "input": {
            "type": "huggingface",
            "name": "Whisper Hinglish model",
            "description": "Hugging Face model ID. Default is Oriserve Apex for Hindi to Hinglish transcription.",
            "default": "Oriserve/Whisper-Hindi2Hinglish-Apex",
            "required": true
          }
        }
      ]
    }
  }
  